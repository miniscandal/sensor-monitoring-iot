{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "jsxImportSource": "preact",
        "baseUrl": "./",
        "paths": {
            "react": [
                "./node_modules/preact/compat/"
            ],
            "react-dom": [
                "./node_modules/preact/compat/"
            ],
            "@core-services/*": [
                "./src/core/services/*"
            ],
            "@features/*": [
                "./src/features/*"
            ],
            "@assets/*": [
                "./src/assets/*"
            ],
            "@mocks/*": [
                "./src/mocks/*"
            ],
            "@shared-components/*": [
                "./src/shared/components/*"
            ],
            "@shared-constants/*": [
                "./src/shared/constants/*"
            ],
            "@shared-contexts/*": [
                "./src/shared/contexts/*"
            ],
            "@shared-hooks/*": [
                "./src/shared/hooks/*"
            ],
            "@shared-utils/*": [
                "./src/shared/utils/*"
            ]
        }
    },
    "include": [
        "src"
    ]
}
